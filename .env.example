# Shared runtime
REQUEST_TIMEOUT=10s
STARTUP_TIMEOUT=45s
ENV_FILE=

# Security
JWT_SECRET=dev-secret
DATA_ENCRYPTION_KEY_ID=local-v1
DATA_ENCRYPTION_KEY_B64=REPLACE_WITH_BASE64_32_BYTE_KEY
DATA_ENCRYPTION_LEGACY_KEYS=

# Docker Compose host ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
INGEST_SERVICE_PORT=8082
PARSER_SERVICE_PORT=8083
LEDGER_SERVICE_PORT=8084
RULE_ENGINE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
ANALYTICS_WRITER_PORT=8087
REALTIME_GATEWAY_PORT=8088
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6380
MONGODB_HOST_PORT=27017
RABBITMQ_HOST_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673
KAFKA_HOST_PORT=9092
CLICKHOUSE_HTTP_PORT=8123
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Shared local development infrastructure endpoints for `go run`
POSTGRES_DSN=postgres://finance:finance@localhost:5434/finance?sslmode=disable
MONGO_URI=mongodb://localhost:27017
REDIS_ADDR=localhost:6380
RABBITMQ_URL=amqp://guest:guest@localhost:5673/
KAFKA_BROKERS=localhost:9092
CLICKHOUSE_DSN=http://finance:finance@localhost:8123

# Shared application data
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
CLICKHOUSE_USER=finance
CLICKHOUSE_PASSWORD=finance
MONGO_DATABASE=finance_os
MONGO_RAW_COLLECTION=raw_imports
MONGO_PARSED_COLLECTION=parsed_imports
CLICKHOUSE_DATABASE=finance_os

# Shared queues and topics
RABBIT_PARSE_QUEUE=parse.statement
RABBIT_NOTIFICATION_QUEUE=send.telegram
RABBIT_NOTIFICATION_DLQ=send.telegram.dlq
KAFKA_IMPORT_TOPIC=statement.uploaded
KAFKA_PARSED_TOPIC=statement.parsed
KAFKA_TRANSACTION_TOPIC=transaction.upserted
KAFKA_ALERT_TOPIC=alert.created
KAFKA_ANALYTICS_TOPIC=transaction.upserted
KAFKA_QUARANTINE_TOPIC=event.quarantine
KAFKA_CONSUMER_RETRY_BACKOFF=2s
KAFKA_CONSUMER_RETRY_MAX_ATTEMPTS=3

# Telegram
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional local service URL overrides for Telegram workflows
INGEST_SERVICE_URL=http://localhost:8082
PARSER_SERVICE_URL=http://localhost:8083
LEDGER_SERVICE_URL=http://localhost:8084
ANALYTICS_SERVICE_URL=http://localhost:8087
